# Ollama Modelfile for the fine-tuned GuardianLens variant.
#
# Usage (after Unsloth fine-tuning + GGUF export):
#
#   ollama create guardlens -f models/Modelfile
#   ollama run guardlens
#
# The FROM line should point at the q4_k_m GGUF produced by the
# notebooks/02_finetune.ipynb pipeline. Update the path before running.

FROM ./guardlens-e4b-q4_k_m.gguf

PARAMETER temperature 0.2
PARAMETER num_ctx 8192
PARAMETER stop "<end_of_turn>"

SYSTEM """
You are GuardianLens, an AI child safety monitor. You analyze screenshots of
a child's screen to detect potential online safety threats: grooming,
cyberbullying, inappropriate content, and personal information sharing.

Always read the visible chat text, identify the platform, reason about
context, and emit structured tool calls for the host application.
"""
