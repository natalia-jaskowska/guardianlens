# GuardianLens environment configuration
# Copy to .env and edit. All values are optional — defaults live in src/guardlens/config.py.
# Nested fields use the GUARDLENS_<section>__<field> convention.

# Logging
GUARDLENS_LOG_LEVEL=INFO
GUARDLENS_SEED=42

# Ollama
GUARDLENS_OLLAMA__HOST=http://localhost:11434
GUARDLENS_OLLAMA__INFERENCE_MODEL=gemma4:26b
GUARDLENS_OLLAMA__FINETUNED_MODEL=guardlens
GUARDLENS_OLLAMA__TIMEOUT_SECONDS=120

# Monitor
GUARDLENS_MONITOR__CAPTURE_INTERVAL_SECONDS=15
GUARDLENS_MONITOR__MONITOR_INDEX=1

# Session tracker
GUARDLENS_SESSION__WINDOW_SIZE=5

# Alerts (off by default)
GUARDLENS_ALERTS__ENABLE_EMAIL=false
GUARDLENS_ALERTS__SMTP_HOST=
GUARDLENS_ALERTS__SMTP_PORT=587
GUARDLENS_ALERTS__SMTP_USER=
GUARDLENS_ALERTS__SMTP_PASSWORD=
GUARDLENS_ALERTS__PARENT_EMAIL=

GUARDLENS_ALERTS__ENABLE_WEBHOOK=false
GUARDLENS_ALERTS__WEBHOOK_URL=
